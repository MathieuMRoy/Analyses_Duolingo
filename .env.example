# ─────────────────────────────────────────────────────
#  Duolingo Engagement Analyzer — Configuration
# ─────────────────────────────────────────────────────

# Clé API Google (obtenue sur https://aistudio.google.com/apikey)
GOOGLE_API_KEY=votre-cle-google-api-ici

# Modèle Gemini à utiliser (par défaut : gemini-2.0-flash)
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Dossier Google Drive local ou copier automatiquement le rapport historique
# Exemple : C:\Users\votre-nom\My Drive\Duolingo\Rapports
GOOGLE_DRIVE_REPORT_DIR=
